# Copy this file to .env and fill in your keys
# Never commit .env to git!

# ModelsLab — image generation (required for quiz1, quiz3, quiz4)
# Get key: https://modelslab.com/dashboard → API Settings
MODELSLAB_API_KEY=your_modelslab_key_here

# ElevenLabs — music generation (required for background music)
# Get free key: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Poe (optional) — higher quality image generation
# Get key: https://poe.com/api_key
POE_API_KEY=your_poe_key_here
